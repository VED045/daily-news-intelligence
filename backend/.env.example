# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/dailynews?retryWrites=true&w=majority

# ─── Google Gemini ────────────────────────────────────────────
# Get free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-your-key-here
GEMINI_MODEL=gemini-1.5-flash

# ─── NewsAPI ─────────────────────────────────────────────────
# Get free key (1000 req/day): https://newsapi.org/register
NEWS_API_KEY=your-newsapi-key-here

# ─── Email (Gmail SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=Dainik-Vidya <your-email@gmail.com>

# ─── App ─────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ─── Scheduler (IST, 24-hour format) ────────────────────────
SCHEDULER_HOUR=7        # Morning run (7:00 AM IST)
SCHEDULER_MINUTE=0
SCHEDULER_HOUR_2=14     # Afternoon run (2:00 PM IST)
SCHEDULER_MINUTE_2=0

# ─── Pipeline limits ─────────────────────────────────────────
MAX_SCRAPER_ARTICLES=100   # RSS articles per run
MAX_NEWS_API_ARTICLES=50   # NewsAPI articles per run
MAX_AI_ARTICLES=15         # Articles sent to Gemini per run

# ─── Rate control ────────────────────────────────────────────
GEMINI_RPM=12              # Gemini requests/min (free tier cap: 15)
