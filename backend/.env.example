# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/dailynews?retryWrites=true&w=majority

# ─── Google Gemini ────────────────────────────────────────────
# Get free API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-your-gemini-api-key-here

# ─── Email (Gmail SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=Daily News Intelligence <your-email@gmail.com>

# ─── App ─────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ─── Scheduler (IST, 7:00 AM default) ───────────────────────
SCHEDULER_HOUR=7
SCHEDULER_MINUTE=0
