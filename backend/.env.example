# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/dailynews

# ─── OpenAI ──────────────────────────────────────────────────
# Leave blank to run in mock mode (no AI summaries)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── Email (Gmail SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=Daily News Intelligence <your-email@gmail.com>

# ─── App ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Scheduler (IST, 7:00 AM default) ───────────────────────
SCHEDULER_HOUR=7
SCHEDULER_MINUTE=0
